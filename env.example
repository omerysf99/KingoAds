# ── Bot Token ────────────────────────────────────────────────────────────────
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# ── Admin Telegram ID'leri (virgülle ayırın) ─────────────────────────────────
ADMIN_IDS=123456789,987654321

# ── Reklam DM Kullanıcı Adı ──────────────────────────────────────────────────
# "Reklam Ver" butonuna tıklayanlar bu kullanıcıya yönlendirilir
ADMIN_USERNAME=@kingoads_admin

# ── Zorunlu Kanal ─────────────────────────────────────────────────────────────
REQUIRED_CHANNEL=@KingoAds
ANNOUNCEMENT_CHANNEL=@KingoAds

# ── TRX (Tron) Cüzdan Adresi ─────────────────────────────────────────────────
TRX_ADDRESS=TXXX_TRX_ADRESINIZ

# ── TRX/TL Kuru (manuel güncelleyin) ─────────────────────────────────────────
# 1 TRX kaç TL ettiğini girin
TRX_TO_TRY=8.5
